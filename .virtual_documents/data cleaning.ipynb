import pandas as pd


df = pd.read_csv('laptops.csv')


df.head()












































temp = df.copy()





temp.insert(loc=1, column='Brand', value=temp['name'].str.split().str[0])





cols = ['processor', 'ram', 'storage', 'display', 'graphics']

temp.loc[temp['name'].str.contains('MacBook'), cols] = (
    temp.loc[temp['name'].str.contains('MacBook'), cols].shift(1, axis=1)
)





temp.loc[temp['name'].str.contains('MacBook'), 'processor'] = (
    temp.loc[temp['name'].str.contains('MacBook'), 'name']
    .str.extract(r'((?:M[1-5]|A\d+)(?:\s*(?:Pro|Max|Ultra))?)', expand=False)
)





store_list = temp[temp['name'].str.contains('Store|Refurbished')].index
temp = temp.drop(index=store_list)





processor_format_problem = temp[temp['processor'].str.startswith('1')].index
snap_list = temp[temp['processor'].str.contains('Snapdragon')].index
intel_problem = list(set(processor_format_problem) - set(snap_list))


temp.loc[intel_problem]['processor'].value_counts()



